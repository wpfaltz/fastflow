###############################################################################
# FastFlow - .env.example
# Copie este arquivo para ".env" e ajuste os valores para o seu ambiente.
#
# Observação:
# - Em DEV, carregue com: from fastflow import load_env; load_env()
# - Em PRD, prefira variáveis de ambiente do sistema (sem .env).
###############################################################################

###############################################################################
# 1) Identidade do servidor Prefect (máquina central com Server + UI)
#
# Preencha com os valores REAIS do servidor (retornos de:
#   - socket.gethostname()
#   - getpass.getuser()
###############################################################################

# Hostname real da máquina onde está o Prefect Server/UI
FASTFLOW_SERVER_HOST=YOUR_SERVER_HOSTNAME

# Username do sistema operacional usado para executar os flows no servidor
FASTFLOW_SERVER_USER=YOUR_SERVER_USERNAME


###############################################################################
# 2) Aliases (nomes "bonitos") para tags quando a execução ocorrer no servidor
#
# Ex.: você quer que na UI apareça "host:prefect-server" em vez do hostname real.
###############################################################################

# Alias aplicado na tag host: quando for execução no servidor
FASTFLOW_SERVER_HOST_TAG=prefect-server

# Alias aplicado na tag user: quando for execução no servidor
FASTFLOW_SERVER_USER_TAG=prefect


###############################################################################
# 3) Tags de ambiente (DEV/PRD)
#
# A FastFlow define env=PRD quando detectar que está rodando no servidor.
# Caso contrário, env=DEV.
###############################################################################

FASTFLOW_ENV_DEV=DEV
FASTFLOW_ENV_PRD=PRD


###############################################################################
# 4) Debug / diagnóstico de tags
#
# Quando ativado, a FastFlow pode imprimir/logar as tags calculadas
# (útil para validar se env/host/user estão sendo detectados corretamente).
###############################################################################

# 0 = desabilitado | 1 = habilitado
FASTFLOW_DEBUG_TAGS=0


###############################################################################
# 5) Logs (gancho para evolução)
#
# Caminho base para logs locais. Pode ser relativo ou absoluto.
# Ex.: ./logs  |  C:\lab\logs  |  /var/log/fastflow
###############################################################################

FASTFLOW_LOG_DIR=./logs

# Nível de log padrão (ex.: DEBUG, INFO, WARNING, ERROR)
FASTFLOW_LOG_LEVEL=INFO


###############################################################################
# 6) Key Vault (gancho para evolução)
#
# URL do serviço de secrets central. Ex.: http://keyvault.lab.local:8080
# Token/credencial pode ser obtido por login (futuro) ou variável local (DEV).
###############################################################################

FASTFLOW_KEYVAULT_URL=http://localhost:8080
FASTFLOW_KEYVAULT_TIMEOUT_SECONDS=10

# (Opcional em DEV) Token estático para testes locais
# Em produção, preferir autenticação/token dinâmico.
FASTFLOW_KEYVAULT_TOKEN=


###############################################################################
# 7) Prefect (opcional)
#
# Se você quiser fixar a API URL do Prefect Server via .env, pode usar a env var
# padrão do Prefect. Ex.: http://SERVER:4200/api
#
# Só preencha se fizer sentido no seu setup.
###############################################################################

PREFECT_API_URL=